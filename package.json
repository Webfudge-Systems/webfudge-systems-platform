{
  "name": "webfudge-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/[(]automobile[)]/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=!backend --filter=!./apps/[(]automobile[)]/*",
    "dev:all": "turbo run dev",
    "dev:books": "turbo run dev --filter=@webfudge/books",
    "dev:crm": "turbo run dev --filter=@webfudge/crm",
    "dev:pm": "turbo run dev --filter=@webfudge/pm",
    "dev:hr": "turbo run dev --filter=@webfudge/hr",
    "dev:recrm": "turbo run dev --filter=@webfudge/real-estate-crm",
    "dev:auto": "turbo run dev --filter=./apps/[(]automobile[)]/*",
    "dev:backend": "turbo run dev --filter=backend",
    "build": "turbo run build",
    "build:accounts": "turbo run build --filter=@webfudge/accounts",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,jsx,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "verify": "node verify-setup.js"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "serwist": "^9.5.11",
    "turbo": "^1.11.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.2.5",
  "dependencies": {
    "@serwist/next": "^9.5.11",
    "ajv": "^8.0.0"
  }
}
