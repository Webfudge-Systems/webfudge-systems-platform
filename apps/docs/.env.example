# Base URL of the Strapi backend API (no trailing slash)
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1338

# Public URL of this docs app
NEXT_PUBLIC_DOCS_APP_URL=http://localhost:3009

# ─── Firebase Auth (docs admin) ─────────────────────────────────────────────
# From Firebase Console → Project settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated emails allowed to access /admin (or use Firebase custom claim docsAdmin=true)
NEXT_PUBLIC_DOCS_ADMIN_EMAILS=admin@webfudge.com

# Firebase Admin SDK (server-side token verification) — from service account JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Shared secret between docs proxy and Strapi (set same value in apps/backend/.env)
DOCS_INTERNAL_API_KEY=

# Set to true to skip Firebase auth locally (dev only)
NEXT_PUBLIC_DOCS_ADMIN_OPEN=true

# Used by the ingest-readme.js script (set to a Super Admin / Admin JWT)
DOCS_ADMIN_TOKEN=
