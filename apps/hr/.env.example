# HR / Fudge People - copy to .env.local for local development overrides

# Backend API (required) - same as CRM/PM local stack
NEXT_PUBLIC_API_URL=http://localhost:1338

# Public URL of this app - drives metadataBase / OG URLs (required for production)
NEXT_PUBLIC_HR_APP_URL=http://localhost:3008

# Production (set in Vercel / hosting project environment variables)
# NEXT_PUBLIC_API_URL=https://api.webfudge.in
# NEXT_PUBLIC_HR_APP_URL=https://people.webfudge.in
