{
  "kind": "collectionType",
  "collectionName": "invoices",
  "info": {
    "singularName": "invoice",
    "pluralName": "invoices",
    "displayName": "Invoice",
    "description": "Customer invoices"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "invoiceNumber":     { "type": "string" },
    "status":            { "type": "enumeration", "enum": ["draft","sent","viewed","partial","paid","overdue","void"], "default": "draft" },
    "invoiceDate":       { "type": "date", "required": true },
    "dueDate":           { "type": "date" },
    "paymentTerms":      { "type": "enumeration", "enum": ["net_15","net_30","net_45","net_60","due_on_receipt","custom"] },
    "currency":          { "type": "string", "default": "INR" },
    "exchangeRate":      { "type": "decimal", "default": 1 },
    "subtotal":          { "type": "integer", "default": 0 },
    "discountType":      { "type": "enumeration", "enum": ["percentage","fixed"], "default": "percentage" },
    "discountValue":     { "type": "decimal", "default": 0 },
    "discountAmount":    { "type": "integer", "default": 0 },
    "taxAmount":         { "type": "integer", "default": 0 },
    "shippingCharge":    { "type": "integer", "default": 0 },
    "adjustment":        { "type": "integer", "default": 0 },
    "total":             { "type": "integer", "default": 0 },
    "balanceDue":        { "type": "integer", "default": 0 },
    "paidAmount":        { "type": "integer", "default": 0 },
    "notes":             { "type": "text" },
    "termsConditions":   { "type": "text" },
    "billingAddress":    { "type": "json" },
    "shippingAddress":   { "type": "json" },
    "sentAt":            { "type": "datetime" },
    "viewedAt":          { "type": "datetime" },
    "paidAt":            { "type": "datetime" },
    "voidedAt":          { "type": "datetime" },
    "voidReason":        { "type": "string" },
    "isBilledFromTime":  { "type": "boolean", "default": false },
    "portalLink":        { "type": "string" },
    "customer":          { "type": "relation", "relation": "manyToOne", "target": "api::contact.contact" },
    "project":           { "type": "relation", "relation": "manyToOne", "target": "api::project.project" },
    "estimate":          { "type": "relation", "relation": "manyToOne", "target": "api::estimate.estimate" },
    "organization":      { "type": "relation", "relation": "manyToOne", "target": "api::organization.organization" },
    "createdByUser":     { "type": "relation", "relation": "manyToOne", "target": "plugin::users-permissions.user" }
  }
}
