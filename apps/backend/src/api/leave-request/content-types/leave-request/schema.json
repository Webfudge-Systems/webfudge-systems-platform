{
  "kind": "collectionType",
  "collectionName": "leave_requests",
  "info": {
    "singularName": "leave-request",
    "pluralName": "leave-requests",
    "displayName": "Leave Request",
    "description": "Employee leave and WFH requests"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "leaveType": {
      "type": "string",
      "required": true
    },
    "fromDate": {
      "type": "date",
      "required": true
    },
    "toDate": {
      "type": "date",
      "required": true
    },
    "days": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "reason": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending"
    },
    "appliedOn": {
      "type": "date"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "rejectionReason": {
      "type": "text"
    },
    "organizationUser": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization-user.organization-user"
    },
    "employeeProfile": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employee-profile.employee-profile"
    },
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization"
    },
    "createdByUser": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "approvedByUser": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
