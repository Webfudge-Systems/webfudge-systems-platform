# Real Estate CRM — copy to .env.local for local development overrides

# Backend API (required)
NEXT_PUBLIC_API_URL=http://localhost:1338

# Public URL of this app — drives metadataBase / OG URLs (required for production)
NEXT_PUBLIC_RE_CRM_APP_URL=http://localhost:3010

# Production (set in Vercel Project Environment Variables)
# NEXT_PUBLIC_API_URL=https://api.webfudge.in
# NEXT_PUBLIC_RE_CRM_APP_URL=https://estate.webfudge.in

# ── Meta Ads integration (server-only — NEVER prefix these with NEXT_PUBLIC) ──

# Shared secret for server-to-server calls to the Strapi /api/re-webhooks/* routes.
# Must match RE_WEBHOOK_SECRET in apps/backend. Generate: openssl rand -hex 32
RE_WEBHOOK_SECRET=

# Meta app credentials (Meta for Developers > your app > Settings > Basic)
META_APP_ID=
META_APP_SECRET=

# Arbitrary string you also paste into the Meta webhook subscription config
META_VERIFY_TOKEN=

# Long-lived access token with leads_retrieval (until per-org OAuth lands in /settings/integrations)
META_ACCESS_TOKEN=

# Pixel / dataset id for Conversions API events (optional but strongly recommended)
META_PIXEL_ID=

# Optional: Events Manager test code while validating CAPI
# META_CAPI_TEST_EVENT_CODE=
